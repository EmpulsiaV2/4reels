PORT=3000
NODE_ENV=production
TMDB_API_KEY=your_tmdb_api_key_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
DISCORD_URL=https://discord.gg/your-invite-here
JWT_SECRET=a-very-long-random-secret-string-here

# ── Neon Postgres ──────────────────────────────────────
# Get this from your Neon dashboard: https://console.neon.tech
# Project → Connection Details → Connection string (use the "pooled" one)
DATABASE_URL=postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── First admin account ────────────────────────────────
# Run: npm run hash yourpassword
# Then paste the output below as ADMIN_PASSWORD_HASH
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=bcrypt_hash_of_your_admin_password
